# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
dist/
build/
*.egg

# Environment
.env
.venv/
env/

# Logs (keep directory, ignore contents)
logs/*.jsonl
logs/*.json
!logs/.gitkeep

# Temp forensic output
/tmp/findevil/

# Large evidence datasets (not committed — fetched separately)
datasets/hacking_case/*.E0*
datasets/**/*.raw
datasets/**/*.dd
datasets/**/*.img
datasets/**/*.mem
datasets/**/*.pcap

# Reports (generated per-run, keep ground truth only)
reports/*.json
!reports/ground_truth/*.json

# Console logs
logs/*.log

# IDE
.vscode/
.idea/

# OS
.DS_Store
Thumbs.db

# Video recordings (demo footage — upload to YouTube/Devpost, not GitHub)
*.mp4
*.mov
*.mkv
*.avi
*.webm
*.m4v
*.flv
*.wmv
*.mp3
*.wav
*.aac
docs/video/recordings/
